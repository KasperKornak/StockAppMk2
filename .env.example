# Public site URL (used for metadata, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Postgres + Auth) — from your Supabase project settings (Settings > Data API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (Settings > API > service_role) — server-only,
# used by the dividend sync cron job. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email for dividend notifications) — not yet wired up
RESEND_API_KEY=

# Massive (formerly Polygon.io) — prices, dividend history, ticker details
MASSIVE_API_KEY=
# Requests/minute ceiling for the Massive client — 5 matches the free
# "Stocks Basic" plan; raise this if you upgrade plans.
MASSIVE_REQUESTS_PER_MINUTE=5

# Shared secret Vercel Cron sends as "Authorization: Bearer <value>" so
# /api/cron/sync-dividends can't be triggered by anyone else. Generate any
# random string (e.g. `openssl rand -hex 32`) and set the same value in
# your Vercel project's env vars.
CRON_SECRET=

# NBP FX rate API (api.nbp.pl) requires no API key

# Cloudflare Turnstile (bot check on login/signup) — site key only; it's
# public and safe client-side. The secret key does NOT go here — paste it
# into Supabase Dashboard > Authentication > Settings > Bot and Abuse
# Protection > Enable Captcha protection (provider: Turnstile) instead,
# where Supabase's own server verifies tokens directly with Cloudflare.
# Leave this blank to disable the widget entirely (dev/testing).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
